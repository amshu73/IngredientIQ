# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# Model Paths
MODEL_DIR=./models
REFERENCE_DATA_DIR=./data/reference

# External APIs
OPEN_BEAUTY_FACTS_API_URL=https://world.openbeautyfacts.org/api/v2
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v2
API_REQUEST_TIMEOUT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/ingredientiq.log

# Cache
ENABLE_CACHE=True
CACHE_TTL=3600

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_RUN_NAME=ingredientiq_production
